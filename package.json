{
  "name": "@klinklabs/fingerprint",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for the Klink Labs Fingerprint API – device fingerprinting, bot detection, VPN detection, and offer validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "klink",
    "fingerprint",
    "fraud-detection",
    "bot-detection",
    "vpn-detection",
    "offer-validation",
    "sdk",
    "typescript"
  ],
  "author": "Klink Finance <dev@klinkfinance.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:KlinkFinance/Fingerprit-Sdk.git"
  },
  "dependencies": {
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "axios": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}
